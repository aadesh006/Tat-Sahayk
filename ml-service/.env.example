# ═══════════════════════════════════════════════
#  Tat-Sahayk ML Service — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True
LOG_LEVEL=INFO

# OpenWeather API (optional — uses mock data if empty)
OPENWEATHER_API_KEY=
WEATHER_API_KEY=

# News API (optional)
NEWS_API_KEY=

# Twitter / X API (optional)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# NOAA (no key needed)
NOAA_BASE_URL=https://api.tidesandcurrents.noaa.gov/api/prod/

# Redis Cache (optional — in-memory fallback if not set)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=

# Cache Settings
CACHE_TTL=3600
CACHE_ENABLED=True

# ML Model Settings
MODEL_PATH=./models
CLIP_MODEL=ViT-B/32
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Logging
LOG_FILE=./logs/ml_service.log

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
